# EBS 자동 다운로드 환경 변수
# 이 파일을 .env 로 복사해서 실제 값을 채워 넣으세요.
#
# 복사 방법:
#   Windows: copy .env.example .env
#   Linux/Mac: cp .env.example .env
#
# ⚠️ 중요: .env 파일은 절대 git 에 올리지 마세요!
#         (.gitignore 에 이미 등록되어 있음)

# EBS 사이트 로그인 정보
EBS_USERNAME=your_ebs_username_here
EBS_PASSWORD=your_ebs_password_here

# (선택) Whisper 모델 - tiny, base, small, medium, large
WHISPER_MODEL=small

# (선택) EBS Downloader 가 MP3 를 저장하는 경로
# EBS Downloader 의 "저장 폴더" 설정과 일치해야 함
EBS_DOWNLOAD_DIR=C:\EBSe
